# Firebase (already hardcoded in lib/firebase.ts, but can override here)
# NEXT_PUBLIC_FIREBASE_API_KEY=

# OAuth Secrets (server-side only)
GITHUB_SECRET=your_github_client_secret
NOTION_SECRET=your_notion_secret
DISCORD_SECRET=your_discord_client_secret
CLOUDFLARE_SECRET=your_cloudflare_client_secret

# Google OAuth (fill in after getting credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# Your deployment URL (important for OAuth redirects)
NEXTAUTH_URL=https://your-app.vercel.app
